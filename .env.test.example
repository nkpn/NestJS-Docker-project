NODE_ENV=test
PORT=3000

# Test DB (local)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=nestuser
DB_PASSWORD=nestpassword
DB_DATABASE=nestdb_test

# Keep empty for local tests to avoid accidental cloud usage.
# DATABASE_URL=

JWT_SECRET=test-secret
JWT_EXPIRES_IN=1h

# RabbitMQ can be mocked in tests; keep value for compatibility.
RABBITMQ_URL=amqp://guest:guest@localhost:5672
