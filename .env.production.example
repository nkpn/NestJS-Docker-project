NODE_ENV=production
PORT=3000

# Preferred for cloud deployment (Neon/Render):
# DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require
DATABASE_SSL=true

# Fallback if DATABASE_URL is not used
# DB_HOST=
# DB_PORT=5432
# DB_USERNAME=
# DB_PASSWORD=
# DB_DATABASE=

JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d

# CloudAMQP / RabbitMQ URL
# RABBITMQ_URL=amqps://user:password@host/vhost
RABBITMQ_URL=
