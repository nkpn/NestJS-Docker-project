NODE_ENV=development
PORT=3000

# Local development (app runs on host machine)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=nestuser
DB_PASSWORD=nestpassword
DB_DATABASE=nestdb

# Do not set DATABASE_URL in development unless you intentionally want
# to run dev against a cloud database.
# DATABASE_URL=

JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Local RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
