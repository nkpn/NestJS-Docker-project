NODE_ENV=development
PORT=3000

# ──────────────────────────────────────────────────────────────
# DATABASE  (pick ONE option)
# ──────────────────────────────────────────────────────────────

# Option A — LOCAL DOCKER (docker compose up)
# Uses individual vars; DATABASE_URL must be absent or empty.
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=nestuser
DB_PASSWORD=nestpassword
DB_DATABASE=nestdb

# Option B — CLOUD / RENDER + NEON
# When DATABASE_URL is set, DB_* vars above are ignored.
# Get this from: neon.tech → project → Connection string
# Required format: postgresql://user:pass@host/db?sslmode=require
# DATABASE_URL=postgresql://neondb_owner:xxxx@ep-xxx.neon.tech/neondb?sslmode=require

# ──────────────────────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ──────────────────────────────────────────────────────────────
# RABBITMQ
# ──────────────────────────────────────────────────────────────

# Local Docker:
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# CloudAMQP (free Little Lemur tier):
# Get from: cloudamqp.com → instance → AMQP URL
# Note: use amqps:// (SSL) for cloud, amqp:// for local
# RABBITMQ_URL=amqps://user:pass@host.rmq2.cloudamqp.com/vhost